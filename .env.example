# Database Configuration (MariaDB)
# Estas variables son para el despliegue con Docker y configuración local
DATABASE_ROOT_PASSWORD=root
DATABASE_NAME=sko_nexus
DATABASE_USER=sko_admin
DATABASE_PASSWORD=sko_password
DATABASE_HOST=localhost
DATABASE_PORT=3306

# Prisma Connection URL
# Para MariaDB remota, usa el host y credenciales correspondientes.
# Si usas IPv6 o configuraciones especiales, asegúrate de urlencode en el password.
DATABASE_URL="mysql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}"